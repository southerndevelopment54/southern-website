# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in all values before starting the services.
# NEVER commit .env to version control.
#
# To generate strong secrets automatically, run:
#   ./init-secrets.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# -----------------------------------------------------------------------------
# MinIO (Application-level credentials for Spring Boot)
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=

# -----------------------------------------------------------------------------
# MinIO (Container root credentials — required at container startup)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# -----------------------------------------------------------------------------
# HashiCorp Vault
# -----------------------------------------------------------------------------
VAULT_ENABLED=true
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=

# -----------------------------------------------------------------------------
# JWT (used by vault-seed script to store secret in Vault)
# Must be at least 64 characters for HS512 algorithm.
# -----------------------------------------------------------------------------
JWT_SECRET=
