# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in all values before starting the services.
# NEVER commit .env to version control.
#
# To generate strong secrets automatically, run:
#   ./init-secrets.sh
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# -----------------------------------------------------------------------------
# MinIO (Application-level credentials for Spring Boot)
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=

# -----------------------------------------------------------------------------
# MinIO (Container root credentials — required at container startup)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# -----------------------------------------------------------------------------
# CORS (cross-origin resource sharing)
# ------------------------------------------------------------------------------
# In production behind nginx (same origin), leave empty.
# For local dev with frontend on localhost:3000, use: http://localhost:3000
# For multiple origins, comma-separate: https://yourdomain.com,https://www.yourdomain.com
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# JWT (must be at least 64 characters for HS512 algorithm)
# -----------------------------------------------------------------------------
JWT_SECRET=
