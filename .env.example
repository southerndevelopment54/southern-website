# Local development environment variables
# Copy this file to .env and fill in your own values
# docker-compose automatically loads .env (this file is ignored by git)

# Database
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# Vault (local dev mode)
VAULT_ENABLED=true
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-token

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_EXTERNAL_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=security-co

# JWT — generate a strong 512-bit secret for production
# This is used by Vault seeding and as a fallback if Vault is disabled
JWT_SECRET=change-me-to-a-long-random-secret-key-min-64-characters-long-please
